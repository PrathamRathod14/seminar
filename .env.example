GROQ_API_KEY=your_real_groq_key_here
ACTIVE_MODELS=llama-4,groq-large,groq-small,qwen-groq
MAX_REPOS=15
PROMPT_CHAR_BUDGET=30000
LLM_CACHE=1
LLM_CACHE_DIR=.llm_cache
LLM_CHUNK_PAUSE_SECONDS=2
REAL_DATA_ONLY=1

# Optional: helps avoid GitHub API rate limits for adoption-gap evidence.
GITHUB_TOKEN=

# Optional: only needed if you enable OpenRouter-backed models.
OPENROUTER_SITE_URL=http://localhost
OPENROUTER_APP_NAME=ros2-llm-arch-recovery
